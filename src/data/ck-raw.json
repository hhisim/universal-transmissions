// ═══════════════════════════════════════════════════════════
// GEO SVG
// ═══════════════════════════════════════════════════════════
function geoSVG(geomStr,col,sz=52){
  const g=(geomStr||'').split(';')[0].trim().toLowerCase();
  const c=sz/2,r=sz*.42;
  let inner='';
  if(g.includes('flower')||g.includes('life'))
    inner=`<circle cx="${c}" cy="${c}" r="${r}" stroke="${col}" stroke-width=".7" fill="none"/>
      ${[0,1,2,3,4,5].map(i=>{const a=Math.PI*i/3;return `<circle cx="${c+r*.6*Math.cos(a)}" cy="${c+r*.6*Math.sin(a)}" r="${r*.6}" stroke="${col}" stroke-width=".4" fill="none" opacity=".5"/>`}).join('')}`;
  else if(g.includes('merkaba')||g.includes('star tetrahedron')){
    const p1=[0,1,2].map(i=>{const a=Math.PI*2*i/3-Math.PI/2;return `${c+r*Math.cos(a)},${c+r*Math.sin(a)}`}).join(' ');
    const p2=[0,1,2].map(i=>{const a=Math.PI*2*i/3+Math.PI/2;return `${c+r*Math.cos(a)},${c+r*Math.sin(a)}`}).join(' ');
    inner=`<polygon points="${p1}" stroke="${col}" stroke-width="1" fill="none"/>
      <polygon points="${p2}" stroke="#d4a847" stroke-width="1" fill="none"/>
      <circle cx="${c}" cy="${c}" r="${r*.2}" stroke="${col}" stroke-width=".6" fill="none" opacity=".6"/>`;
  } else if(g.includes('metatron')){
    inner=`<circle cx="${c}" cy="${c}" r="${r}" stroke="${col}" stroke-width=".5" fill="none"/>
      ${[0,1,2,3,4,5].map(i=>{const a=Math.PI*i/3;const x=c+r*.5*Math.cos(a),y=c+r*.5*Math.sin(a);return `<circle cx="${x}" cy="${y}" r="${r*.5}" stroke="${col}" stroke-width=".4" fill="none" opacity=".6"/>`}).join('')}
      <circle cx="${c}" cy="${c}" r="${r*.5}" stroke="${col}" stroke-width=".5" fill="none"/>`;
  } else if(g.includes('sri yantra')){
    const t1=[0,1,2].map(i=>{const a=Math.PI*2*i/3-Math.PI/2;return `${c+r*Math.cos(a)},${c+r*Math.sin(a)}`}).join(' ');
    const t2=[0,1,2].map(i=>{const a=Math.PI*2*i/3+Math.PI/2;return `${c+r*.8*Math.cos(a)},${c+r*.8*Math.sin(a)}`}).join(' ');
    const t3=[0,1,2].map(i=>{const a=Math.PI*2*i/3-Math.PI/2;return `${c+r*.6*Math.cos(a)},${c+r*.6*Math.sin(a)}`}).join(' ');
    inner=`<polygon points="${t1}" stroke="${col}" stroke-width=".8" fill="none"/>
      <polygon points="${t2}" stroke="#d4a847" stroke-width=".8" fill="none"/>
      <polygon points="${t3}" stroke="${col}" stroke-width=".6" fill="none" opacity=".6"/>
      <circle cx="${c}" cy="${c}" r="${r}" stroke="${col}" stroke-width=".4" fill="none" opacity=".4"/>`;
  } else if(g.includes('cube')||g.includes('hexahedron')){
    const s=r*.75;
    inner=`<rect x="${c-s}" y="${c-s}" width="${s*2}" height="${s*2}" stroke="${col}" stroke-width=".9" fill="none"/>
      <line x1="${c-s}" y1="${c-s}" x2="${c-s*.5}" y2="${c-s*1.3}" stroke="${col}" stroke-width=".5" opacity=".5"/>
      <line x1="${c+s}" y1="${c-s}" x2="${c+s*.5}" y2="${c-s*1.3}" stroke="${col}" stroke-width=".5" opacity=".5"/>
      <line x1="${c+s*.5}" y1="${c-s*1.3}" x2="${c-s*.5}" y2="${c-s*1.3}" stroke="${col}" stroke-width=".5" opacity=".5"/>`;
  } else if(g.includes('dodecahedron')){
    const pts=[0,1,2,3,4].map(i=>{const a=Math.PI*2*i/5-Math.PI/2;return `${c+r*Math.cos(a)},${c+r*Math.sin(a)}`}).join(' ');
    const pts2=[0,1,2,3,4].map(i=>{const a=Math.PI*2*i/5+Math.PI/10;return `${c+r*.55*Math.cos(a)},${c+r*.55*Math.sin(a)}`}).join(' ');
    inner=`<polygon points="${pts}" stroke="${col}" stroke-width=".9" fill="none"/>
      <polygon points="${pts2}" stroke="${col}" stroke-width=".6" fill="none" opacity=".6"/>
      <circle cx="${c}" cy="${c}" r="${r*.2}" stroke="${col}" stroke-width=".5" fill="none"/>`;
  } else if(g.includes('tetrahedron')||g.includes('triangle')){
    const pts=[0,1,2].map(i=>{const a=Math.PI*2*i/3-Math.PI/2;return `${c+r*Math.cos(a)},${c+r*Math.sin(a)}`}).join(' ');
    inner=`<polygon points="${pts}" stroke="${col}" stroke-width="1" fill="none"/>
      <circle cx="${c}" cy="${c}" r="${r*.2}" stroke="${col}" stroke-width=".5" fill="none" opacity=".6"/>`;
  } else if(g.includes('octahedron')){
    inner=`<polygon points="${c},${c-r} ${c+r*.75},${c} ${c},${c+r} ${c-r*.75},${c}" stroke="${col}" stroke-width="1" fill="none"/>
      <line x1="${c-r*.75}" y1="${c}" x2="${c+r*.75}" y2="${c}" stroke="${col}" stroke-width=".4" opacity=".4"/>`;
  } else if(g.includes('icosahedron')){
    const pts=[0,1,2,3,4].map(i=>{const a=Math.PI*2*i/5-Math.PI/2;return `${c+r*Math.cos(a)},${c+r*Math.sin(a)}`}).join(' ');
    const pts2=[0,1,2,3,4].map(i=>{const a=Math.PI*2*i/5+Math.PI/5;return `${c+r*.6*Math.cos(a)},${c+r*.6*Math.sin(a)}`}).join(' ');
    inner=`<polygon points="${pts}" stroke="${col}" stroke-width=".9" fill="none"/>
      <polygon points="${pts2}" stroke="${col}" stroke-width=".7" fill="none" opacity=".7"/>`;
  } else if(g.includes('circle')||g.includes('sphere')||g.includes('point')){
    inner=`<circle cx="${c}" cy="${c}" r="${r}" stroke="${col}" stroke-width=".9" fill="none"/>
      <circle cx="${c}" cy="${c}" r="${r*.5}" stroke="${col}" stroke-width=".5" fill="none" opacity=".5"/>
      <circle cx="${c}" cy="${c}" r="${r*.1}" fill="${col}" opacity=".7"/>`;
  } else if(g.includes('spiral')){
    let d=`M${c} ${c}`;
    for(let i=0;i<=720;i+=8){const a=i*Math.PI/180,rd=r*i/720;d+=` L${c+rd*Math.cos(a)} ${c+rd*Math.sin(a)}`}
    inner=`<path d="${d}" stroke="${col}" stroke-width=".7" fill="none"/>`;
  } else if(g.includes('vesica')){
    inner=`<circle cx="${c-r*.4}" cy="${c}" r="${r*.75}" stroke="${col}" stroke-width=".7" fill="none"/>
      <circle cx="${c+r*.4}" cy="${c}" r="${r*.75}" stroke="${col}" stroke-width=".7" fill="none"/>`;
  } else if(g.includes('cross')){
    inner=`<line x1="${c}" y1="${c-r}" x2="${c}" y2="${c+r}" stroke="${col}" stroke-width="1"/>
      <line x1="${c-r}" y1="${c}" x2="${c+r}" y2="${c}" stroke="${col}" stroke-width="1"/>
      <circle cx="${c}" cy="${c}" r="${r*.15}" fill="${col}" opacity=".8"/>`;
  } else if(g.includes('square')){
    const s=r*.85;
    inner=`<rect x="${c-s}" y="${c-s}" width="${s*2}" height="${s*2}" stroke="${col}" stroke-width=".9" fill="none"/>
      <line x1="${c-s}" y1="${c-s}" x2="${c+s}" y2="${c+s}" stroke="${col}" stroke-width=".4" opacity=".4"/>
      <line x1="${c+s}" y1="${c-s}" x2="${c-s}" y2="${c+s}" stroke="${col}" stroke-width=".4" opacity=".4"/>`;
  } else {
    // Default: mandala rings
    inner=`<circle cx="${c}" cy="${c}" r="${r}" stroke="${col}" stroke-width=".7" fill="none"/>
      <circle cx="${c}" cy="${c}" r="${r*.65}" stroke="${col}" stroke-width=".5" fill="none" opacity=".6"/>
      <circle cx="${c}" cy="${c}" r="${r*.3}" stroke="${col}" stroke-width=".5" fill="none" opacity=".5"/>
      ${[0,1,2,3,4,5].map(i=>{const a=Math.PI*i/3;return `<line x1="${c}" y1="${c}" x2="${c+r*Math.cos(a)}" y2="${c+r*Math.sin(a)}" stroke="${col}" stroke-width=".3" opacity=".3"/>`}).join('')}`;
  }
  return `<svg viewBox="0 0 ${sz} ${sz}" xmlns="http://www.w3.org/2000/svg" width="${sz}" height="${sz}">${inner}</svg>`;
}

